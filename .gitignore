# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
dbx_token.json

# ── Runtime state (auto-generated, changes constantly) ────────────────────────
state.json
history.json

# ── Config (contains your board IDs and subdomain — keep private) ─────────────
config.json
config.json.bak

# ── Private reports / internal docs ───────────────────────────────────────────
security/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Next.js / Node ────────────────────────────────────────────────────────────
web/node_modules/
web/.next/
web/out/
web/.turbopack/
web/tsconfig.tsbuildinfo
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
# The api/logs/ route is source code, not a log directory
!web/app/api/logs/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Claude Code (personal AI session data) ────────────────────────────────────
# Keep launch.json (dev server config) but ignore everything else
.claude/*
!.claude/launch.json
