# Copy this file to a new file named exactly: .env
# Then fill in your real tokens below.
# NEVER share the .env file or commit it to git — it contains secret keys.

# Your Monday.com API token.
# Get it from: monday.com → click your avatar (top right) → Admin → API
MONDAY_API_TOKEN=your_monday_token_here

# Your Dropbox API access token.
# Get it from: https://www.dropbox.com/developers/apps
# (See the setup instructions in README or ask Claude to walk you through it)
DROPBOX_ACCESS_TOKEN=your_dropbox_token_here
